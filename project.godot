; ---------------------------------------------------------------
; ZeroDayMMO custom project settings
; These are the single source of truth for all server, admin,
; and database configuration. Override via env vars at runtime.
; ---------------------------------------------------------------

[zeroday]

server/url="ws://localhost:8080/game"
server/url_default="ws://localhost:8080/game"
server/name="ZeroDayMMO"
server/name_default="ZeroDayMMO"

server/port=8080
server/port_default=8080
server/max_connections=2000
server/max_connections_default=2000
server/max_connections_per_ip=8
server/max_connections_per_ip_default=8
server/max_players=1000
server/max_players_default=1000
server/task_generation_interval=30000
server/task_generation_interval_default=30000
server/network_node_count=500
server/network_node_count_default=500

server/starting_cpu=100
server/starting_cpu_default=100
server/starting_ram=256
server/starting_ram_default=256
server/starting_bandwidth=50
server/starting_bandwidth_default=50
server/starting_credits=0
server/starting_credits_default=0

server/snapshot_interval_ms=60000
server/snapshot_interval_ms_default=60000
server/idle_timeout_ms=300000
server/idle_timeout_ms_default=300000
server/sweep_interval_ms=30000
server/sweep_interval_ms_default=30000
server/regen_interval_ms=5000
server/regen_interval_ms_default=5000

admin/username="admin"
admin/username_default="admin"
admin/password="zeroday-admin-1337"
admin/password_default="zeroday-admin-1337"
admin/token="zeroday-admin-secret-change-me"
admin/token_default="zeroday-admin-secret-change-me"
admin/port=8081
admin/port_default=8081
admin/rate_limit=30
admin/rate_limit_default=30
admin/log_retention_hours=168
admin/log_retention_hours_default=168

database/url="jdbc:sqlite:data/zeroday.db"
database/url_default="jdbc:sqlite:data/zeroday.db"
database/user=""
database/user_default=""
database/password=""
database/password_default=""
database/max_pool_size=10
database/max_pool_size_default=10
database/connection_timeout=30000
database/connection_timeout_default=30000

data_dir="data"
data_dir_default="data"