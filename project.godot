; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="ZeroDayMMO"
config/description="MMORPG Hacking Simulator — 2.5D terminal-based game client"
config/version="1.0.0"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

ZeroDayCore="*res://scripts/core/zero_day_core.gd"
NetworkManager="*res://scripts/core/network_manager.gd"
GameManager="*res://scripts/core/game_manager.gd"
UIManager="*res://scripts/core/ui_manager.gd"
ServerConfig="*res://scripts/core/server_config.gd"
TerminalParser="*res://scripts/systems/terminal/terminal_parser.gd"
EnvironmentVariables="*res://scripts/core/environment_variables.gd"
SpriteManager="*res://scripts/core/sprite_manager.gd"
NodeController="*res://scripts/systems/gameplay/node_controller.gd"
PlayerSpawnManager="*res://scripts/systems/gameplay/player_spawn_manager.gd"
BaseManager="*res://scripts/systems/gameplay/base_manager.gd"
EventManager="*res://scripts/systems/gameplay/event_manager.gd"
TutorialManager="*res://scripts/systems/gameplay/tutorial_manager.gd"
SkillTree="*res://scripts/systems/character/skill_tree.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=0

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0, 0, 0, 1)

[input]

