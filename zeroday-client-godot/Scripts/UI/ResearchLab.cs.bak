using Godot;
using ZeroDay.Managers;
using System.Collections.Generic;
using System.Linq;
using System.Threading.Tasks;
using ZeroDay.Effects;

namespace ZeroDay.UI
{
    public partial class ResearchLab : Control
    {
        [ExportGroup("Panels")]
        [Export] public Control Panel;
        [Export] public PackedScene RecipeItemPrefab;
        [Export] public PackedScene InventoryItemPrefab;
        [Export] public Control RecipeContainer;
        [Export] public Control InventoryContainer;

        [ExportGroup("Details")]
        [Export] public RichTextLabel SelectedRecipeName;
        [Export] public RichTextLabel SelectedRecipeDesc;
        [Export] public RichTextLabel SelectedRecipeIngredients;
        [Export] public RichTextLabel SelectedRecipeTime;
        [Export] public Button ResearchButton;

        [ExportGroup("Inventory")]
        [Export] public RichTextLabel InventoryCountText;
        [Export] public Button GatherButton;

        [ExportGroup("Active Research")]
        [Export] public Control ActiveResearchContainer;
        [Export] public PackedScene ActiveResearchPrefab;
        [Export] public TextureRect ResearchProgressFill;

        [ExportGroup("Animation")]
        [Export] public float ListAnimDelay = 0.04f;
        [Export] public float GatherDuration = 0.8f;

        private string selectedRecipeId;

        public override void _Ready()
        {
            if (ResearchButton != null)
                ResearchButton.Pressed += OnStartResearch;
            if (GatherButton != null)
                GatherButton.Pressed += OnGatherFragment;
        }

        public void Show()
        {
            if (Panel != null)
            {
if (                Panel is CanvasItem ci) ci.Visible = true;
                var tween = CreateTween();
                tween.TweenProperty(Panel, "modulate", new Godot.Color(1, 1, 1, 0), 0);
                tween.TweenProperty(Panel, "modulate", Godot.Colors.White, 0.3f);
                RefreshAll();
            }
        }

        public void Hide()
        {
            if (Panel != null)
            {
                var tween = CreateTween();
                tween.TweenProperty(Panel, "modulate", Godot.Colors.White, 0);
                tween.TweenProperty(Panel, "modulate", new Godot.Color(1, 1, 1, 0), 0.25f);
                tween.TweenCallback(Callable.if (From(() => Panel is CanvasItem ci) ci.Visible = false));
            }
        }

        public void Toggle()
        {
            if (Panel != null)
            {
                if (Panel.Visible) Hide();
                else Show();
            }
        }

        async void RefreshAll()
        {
            await Task.WhenAll(
                RefreshRecipes(),
                RefreshInventory(),
                RefreshActiveResearch()
            );
        }

        async Task RefreshRecipes()
        {
            if (RecipeContainer == null || RecipeItemPrefab == null) return;

            foreach (var child in RecipeContainer.GetChildren()) child.QueueFree();

            var result = await GameManager.Instance?.GetNode<Managers.NetworkManager>("/root/NetworkManager")?.SendAndWait(
                new Godot.Collections.Dictionary { ["type"] = "research_recipes" }
            );

            if (result == null || !result.ContainsKey("recipes")) return;

            var recipesJson = Json.Stringify(result["recipes"]);
            var recipesArray = Json.ParseString(recipesJson).AsGodotArray();

            if (recipesArray == null) return;

            float delay = 0f;
            foreach (var recipeDict in recipesArray)
            {
                var recipe = recipeDict.AsGodotDictionary();
                var node = RecipeItemPrefab.Instantiate();
                RecipeContainer.AddChild(node);

                var text = node.GetNodeOrNull<RichTextLabel>("Label");
                if (text != null)
                {
                    string rarityColor = recipe["resultRarity"].AsString() switch
                    {
                        "COMMON" => "#808080",
                        "UNCOMMON" => "#00FF00",
                        "RARE" => "#4488FF",
                        "EPIC" => "#AA44FF",
                        "LEGENDARY" => "#FF8800",
                        _ => "#FFFFFF"
                    };
                    text.Text = $"[color={rarityColor}][{recipe["resultRarity"].AsString()}][/color] {recipe["name"].AsString()}";
                }

                var btn = node.GetNodeOrNull<Button>("Button");
                if (btn != null)
                {
                    string rid = recipe["id"].AsString();
                    btn.Pressed += () => ShowRecipeDetail(recipe, rid);
                }

                delay += ListAnimDelay;
            }
        }

        async Task RefreshInventory()
        {
            if (InventoryContainer == null || InventoryItemPrefab == null) return;

            foreach (var child in InventoryContainer.GetChildren()) child.QueueFree();

            var result = await GameManager.Instance?.GetNode<Managers.NetworkManager>("/root/NetworkManager")?.SendAndWait(
                new Godot.Collections.Dictionary { ["type"] = "research_inventory" }
            );

            if (result == null || !result.ContainsKey("inventory")) return;

            var invJson = Json.Stringify(result["inventory"]);
            var items = Json.ParseString(invJson).AsGodotArray();

            if (items == null) return;

            if (InventoryCountText != null)
                InventoryCountText.Text = $"Items: {items.Count}";

            float delay = 0f;
            foreach (var itemDict in items)
            {
                var item = itemDict.AsGodotDictionary();
                var node = InventoryItemPrefab.Instantiate();
                InventoryContainer.AddChild(node);

                var text = node.GetNodeOrNull<RichTextLabel>("Label");
                if (text != null)
                {
                    string color = item["rarity"].AsString() switch
                    {
                        "COMMON" => "#808080",
                        "UNCOMMON" => "#00FF00",
                        "RARE" => "#4488FF",
                        "EPIC" => "#AA44FF",
                        "LEGENDARY" => "#FF8800",
                        _ => "#FFFFFF"
                    };
                    text.Text = $"[color={color}]{item["name"].AsString()}[/color]\n[size=70%]{item["description"].AsString()}[/size]";
                }

                var btn = node.GetNodeOrNull<Button>("Button");
                if (btn != null && item["type"].AsString() == "ZERO_DAY_EXPLOIT")
                {
                    string iid = item["id"].AsString();
                    btn.Pressed += () => OnUseItem(iid);
                }

                delay += ListAnimDelay * 0.7f;
            }
        }

        async Task RefreshActiveResearch()
        {
            if (ActiveResearchContainer == null || ActiveResearchPrefab == null) return;

            foreach (var child in ActiveResearchContainer.GetChildren()) child.QueueFree();

            var result = await GameManager.Instance?.GetNode<Managers.NetworkManager>("/root/NetworkManager")?.SendAndWait(
                new Godot.Collections.Dictionary { ["type"] = "research_status" }
            );

            if (result == null || !result.ContainsKey("active_research")) return;

            var statusJson = Json.Stringify(result["active_research"]);
            var statusList = Json.ParseString(statusJson).AsGodotArray();

            if (statusList == null) return;

            foreach (var rsDict in statusList)
            {
                var rs = rsDict.AsGodotDictionary();
                var node = ActiveResearchPrefab.Instantiate();
                ActiveResearchContainer.AddChild(node);

                var text = node.GetNodeOrNull<RichTextLabel>("Label");
                if (text != null)
                {
                    bool completed = rs["completed"].AsBool();
                    bool claimed = rs["claimed"].AsBool();
                    if (completed && !claimed)
                    {
                        text.Text = $"[color=#00FF00]COMPLETED: {rs["recipeId"].AsString()}[/color]";
                        var btn = node.GetNodeOrNull<Button>("Button");
                        if (btn != null)
                        {
                            string rid = rs["recipeId"].AsString();
                            btn.Pressed += () => OnClaimResearch(rid);
                        }
                    }
                    else
                    {
                        text.Text = $"[color=#FFFF00]In progress: {rs["recipeId"].AsString()}[/color]";
                    }
                }
            }
        }

        void ShowRecipeDetail(Godot.Collections.Dictionary recipe, string recipeId)
        {
            selectedRecipeId = recipeId;

            AnimateTextChange(SelectedRecipeName, $"[{recipe["resultRarity"].AsString()}] {recipe["name"].AsString()}");
            AnimateTextChange(SelectedRecipeDesc, recipe["description"].AsString());

            if (SelectedRecipeIngredients != null)
            {
                var ingredients = recipe["ingredients"].AsGodotArray();
                if (ingredients != null)
                {
                    var lines = new List<string>();
                    foreach (var ing in ingredients)
                    {
                        var ingDict = ing.AsGodotDictionary();
                        lines.Add($"  {ingDict["quantity"].As<int>()}x {ingDict["itemType"].AsString()} (min {ingDict["minRarity"].AsString()})");
                    }
                    AnimateTextChange(SelectedRecipeIngredients, "Ingredients:\n" + string.Join("\n", lines));
                }
            }

            AnimateTextChange(SelectedRecipeTime, $"Crafting time: {recipe["craftingTimeMs"].As<int>() / 1000}s | Lv.{recipe["requiredLevel"].As<int>()}");

            if (ResearchButton != null)
            {
if (                ResearchButton is CanvasItem ci) ci.Visible = true;
            }
        }

        void AnimateTextChange(RichTextLabel text, string newValue)
        {
            if (text == null) return;
            var tween = CreateTween();
            tween.TweenProperty(text, "modulate", new Godot.Color(1, 1, 1, 0), 0.1f);
            tween.TweenCallback(Callable.From(() => text.Text = newValue ?? ""));
            tween.TweenProperty(text, "modulate", Godot.Colors.White, 0.15f);
        }

        async void OnStartResearch()
        {
            if (string.IsNullOrEmpty(selectedRecipeId)) return;

            if (ResearchButton != null) ResearchButton.Disabled = true;

            if (ScreenEffects.Instance != null)
                ScreenEffects.Instance.PulseBorder(Colors.Magenta, 0.5f);

            var result = await GameManager.Instance?.GetNode<Managers.NetworkManager>("/root/NetworkManager")?.SendAndWait(
                new Godot.Collections.Dictionary
                {
                    ["type"] = "research_start",
                    ["recipe_id"] = selectedRecipeId
                }
            );

            if (result != null && result.ContainsKey("progress"))
            {
                GameManager.Instance?.AppendTerminalOutput("Research started! Come back later to claim the result.", "#00ffff");
                if (ScreenEffects.Instance != null)
                    ScreenEffects.Instance.Flash(new Godot.Color(0.5f, 0f, 1f, 0.3f), 0.3f);
                RefreshAll();
            }
            else
            {
                string msg = result?.GetValueOrDefault("message", "Research failed")?.ToString() ?? "Research failed";
                GameManager.Instance?.AppendTerminalOutput($"[ERROR] {msg}", "#ff4444");
            }

            if (ResearchButton != null) ResearchButton.Disabled = false;
        }

        async void OnClaimResearch(string recipeId)
        {
            var result = await GameManager.Instance?.GetNode<Managers.NetworkManager>("/root/NetworkManager")?.SendAndWait(
                new Godot.Collections.Dictionary
                {
                    ["type"] = "research_claim",
                    ["recipe_id"] = recipeId
                }
            );

            if (result != null && result.ContainsKey("item"))
            {
                GameManager.Instance?.AppendTerminalOutput("Research completed! Item added to inventory.", "#00ff00");
                if (ScreenEffects.Instance != null)
                    ScreenEffects.Instance.HackSequence();
                RefreshAll();
            }
        }

        async void OnGatherFragment()
        {
            if (GatherButton != null) GatherButton.Disabled = true;

            if (ScreenEffects.Instance != null)
                ScreenEffects.Instance.PulseBorder(new Godot.Color(0f, 1f, 0.5f, 0.5f), GatherDuration * 0.5f);

            _ = GatherAnimationAsync();

            var result = await GameManager.Instance?.GetNode<Managers.NetworkManager>("/root/NetworkManager")?.SendAndWait(
                new Godot.Collections.Dictionary { ["type"] = "research_gather" }
            );

            if (result != null && result.ContainsKey("item"))
            {
                var itemDict = result["item"].AsGodotDictionary();
                GameManager.Instance?.AppendTerminalOutput($"Gathered: {itemDict["name"].AsString()} ({itemDict["rarity"].AsString()})", "#00ff00");
                if (ScreenEffects.Instance != null)
                    ScreenEffects.Instance.Flash(new Godot.Color(0f, 1f, 0.3f, 0.4f), 0.3f);
                RefreshAll();
            }
            else
            {
                string msg = result?.GetValueOrDefault("message", "Gather failed")?.ToString() ?? "Gather failed";
                GameManager.Instance?.AppendTerminalOutput($"[ERROR] {msg}", "#ff4444");
            }

            if (GatherButton != null) GatherButton.Disabled = false;
        }

        async System.Threading.Tasks.Task GatherAnimationAsync()
        {
            if (InventoryCountText == null) return;
            string original = InventoryCountText.Text;
            string[] gatherMsgs = { "Scanning network...", "Locating fragments...", "Extracting data...", "Fragment acquired!" };

            foreach (var msg in gatherMsgs)
            {
                InventoryCountText.Text = msg;
                await ToSignal(GetTree().CreateTimer(GatherDuration * 0.2f), "timeout");
            }
        }

        async void OnUseItem(string itemId)
        {
            var result = await GameManager.Instance?.GetNode<Managers.NetworkManager>("/root/NetworkManager")?.SendAndWait(
                new Godot.Collections.Dictionary
                {
                    ["type"] = "research_use_item",
                    ["item_id"] = itemId
                }
            );

            if (result != null && result.ContainsKey("message"))
            {
                GameManager.Instance?.AppendTerminalOutput(result["message"].ToString(), "#00ff00");
                if (ScreenEffects.Instance != null)
                    ScreenEffects.Instance.HackSequence();
                RefreshAll();
            }
        }
    }

    [System.Serializable]
    public class RecipeUI
    {
        public string id;
        public string name;
        public string description;
        public string resultType;
        public string resultName;
        public string resultRarity;
        public List<object> ingredients;
        public long craftingTimeMs;
        public int requiredLevel;
        public long xpReward;
    }

    [System.Serializable]
    public class IngredientUI
    {
        public string itemType;
        public int quantity;
        public string minRarity;
        public long creditsCost;
    }

    [System.Serializable]
    public class InventoryItemUI
    {
        public string id;
        public string type;
        public string name;
        public string description;
        public int quantity;
        public string rarity;
    }

    [System.Serializable]
    public class ResearchStatusUI
    {
        public string recipeId;
        public long startedAt;
        public bool completed;
        public bool claimed;
    }
}
